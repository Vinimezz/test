{
"update_url": "https://clients2.google.com/service/update2/crx",

    "manifest_version": 3,
    "key": "",
    "name": "Superpower for Gemini™",
    "version": "1.2.3",
    "default_locale": "en",
    "description": "__MSG_extDescription__",
    "permissions": [
        "activeTab",
        "tabs",
        "storage",
        "scripting",
        "webRequest",
        "unlimitedStorage",
        "alarms"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "host_permissions": [
        "*://gemini.google.com/*"
    ],
    "optional_permissions": [
        "identity"
    ],
    "oauth2": {
        "client_id": "660667966525-6840t2k5u65l4o5ketqjrdtqa9m95336.apps.googleusercontent.com",
        "scopes": [
            "https://www.googleapis.com/auth/drive.appdata"
        ]
    },
    "optional_host_permissions": [
        "https://api.lemonsqueezy.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "*://gemini.google.com/*"
            ],
            "js": [
                "spoof_injector.js"
            ],
            "run_at": "document_start",
            "world": "MAIN"
        },
        {
            "matches": [
                "*://gemini.google.com/*"
            ],
            "css": [
                "content.css"
            ],
            "js": [
                "lib/docx.umd.min.js",
                "lib/jspdf.umd.min.js",
                "lib/jspdf-autotable.min.js",
                "lib/pdf-fonts.js",
                "content.js"
            ],
            "run_at": "document_end"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "content.css",
                "popup.css",
                "icons/icon48.png",
                "guide.html",
                "guide.js",
                "welcome.html",
                "welcome.js",
                "lib/docx.umd.min.js",
                "lib/jspdf.umd.min.js",
                "lib/jspdf-autotable.min.js",
                "lib/pdf-fonts.js"
            ],
            "matches": [
                "*://gemini.google.com/*"
            ]
        }
    ],
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "commands": {
        "open-gemini": {
            "suggested_key": {
                "default": "Alt+Shift+G"
            },
            "description": "Open Gemini in a new tab"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}